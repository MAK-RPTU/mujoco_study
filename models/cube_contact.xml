<!--
  cube_contact.xml — Contact-model demonstration.

  A single box dropped onto a plane. The whole point of this file is the
  `solref` / `solimp` parameters on the contacting geoms. Change them in
  experiments/02_contact_solref_solimp.py and watch the box sink, bounce,
  or jitter.

  solref = "timeconst dampratio"
      timeconst : time constant of the virtual contact spring-damper (s).
                  Smaller -> stiffer contact (approached faster).
      dampratio : damping ratio. 1.0 = critically damped (no bounce).
                  <1 underdamped (bouncy), >1 overdamped (sluggish).

  solimp = "dmin dmax width midpoint power"
      Controls how constraint impedance ramps from dmin (far) to dmax
      (deep penetration). Higher dmax -> harder contact at depth.

  NOTE: condim on the floor geom sets the friction-cone dimensionality.
        1 = frictionless, 3 = tangential friction (the usual default),
        4 = + torsional, 6 = + rolling.
-->
<mujoco model="cube_contact">
  <option timestep="0.002" integrator="implicitfast"/>

  <visual>
    <global offwidth="1280" offheight="720"/>
    <quality shadowsize="2048"/>
  </visual>

  <default>
    <!-- Default class: every geom inherits these unless overridden.
         This is the <default> inheritance the notes mention. -->
    <geom friction="1 0.005 0.0001" solref="0.02 1" solimp="0.9 0.95 0.001"/>
  </default>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>

    <!-- The floor. condim=3 => tangential friction. -->
    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.3 0.4 0.5 1"
          condim="3"/>

    <body name="cube" pos="0 0 0.5">
      <freejoint name="cube_free"/>
      <geom name="cube_geom" type="box" size="0.1 0.1 0.1"
            rgba="0.9 0.5 0.2 1" mass="1"/>
    </body>
  </worldbody>
</mujoco>
